# GitHub OAuth Configuration
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/api/github/callback

# Workspace Configuration
WORKSPACE_PATH=/path/to/your/workspace

# Development Mode (bypass GitHub requirement for local testing)
DEV_MODE=true

# LLM API Keys (at least one required)
# Get Gemini key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Claude via EcoMagent API (currently unavailable - connection timeout)
# ANTHROPIC_BASE_URL=https://api.ecomagent.in/v1
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_API_KEY=sk-9e4e67da7d93bd7fe1bed6e3aaa78bf7b908c2186c170d8a
# ANTHROPIC_MODEL=claude-opus-4.6

# Claude Code Omniroute Proxy (LOCAL FALLBACK)
ANTHROPIC_BASE_URL=http://localhost:20128/v1
ANTHROPIC_AUTH_TOKEN=sk-1703362f337860d0-440cde-b08c8383
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=kr/claude-sonnet-4.5

# Optional: Other LLM providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
